{
  "name": "@robynn-ai/cli",
  "version": "0.1.0",
  "description": "Robynn CLI and local MCP bridge for Robynn organizations.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "build:cli": "rm -rf dist && tsup src/cli/index.ts --format cjs --outDir dist && mv dist/index.cjs dist/robynn",
    "build": "pnpm typecheck && pnpm build:cli",
    "prepack": "pnpm build:cli"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/ext-apps": "1.1.2",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.7.5",
    "commander": "^14.0.3",
    "hono": "^4.7.4",
    "tsup": "^8.5.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.6.0"
  },
  "bin": {
    "robynn": "dist/robynn"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robynnai/robynnv3-mcp-connector.git"
  },
  "bugs": {
    "url": "https://github.com/robynnai/robynnv3-mcp-connector/issues"
  },
  "homepage": "https://github.com/robynnai/robynnv3-mcp-connector#readme"
}
