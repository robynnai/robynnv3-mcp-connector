{
  "name": "robynn-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "build:cli": "tsup src/cli/index.ts --format cjs --outDir dist && mv dist/index.cjs dist/cli.cjs",
    "build": "pnpm typecheck && pnpm build:cli"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/ext-apps": "1.1.2",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.7.5",
    "commander": "^14.0.3",
    "hono": "^4.7.4",
    "tsup": "^8.5.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.6.0"
  },
  "bin": {
    "robynn": "./dist/cli.cjs"
  }
}
